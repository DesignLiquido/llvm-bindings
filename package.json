{
    "name": "@designliquido/llvm-bindings",
    "version": "0.0.2",
    "description": "LLVM bindings for Node.js/JavaScript/TypeScript",
    "keywords": [
        "llvm",
        "llvm-bindings",
        "llvm-node",
        "llvm-ts",
        "llvm-typescript",
        "llvm-js",
        "llvm-javascript"
    ],
    "license": "MIT",
    "author": "Design Liquido",
    "main": "dist/index.js",
    "types": "llvm-bindings.d.ts",
    "repository": {
        "type": "git",
        "url": "https://github.com/DesignLiquido/llvm-bindings.git"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "yarn build:ts",
        "build:ts": "tsc",
        "prepare": "yarn build:ts",
        "postinstall": "cmake-js compile",
        "build:debug": "cmake-js build -D",
        "build:release": "cmake-js build",
        "clear": "rimraf build dist",
        "test:legacy": "ts-node test/index.ts",
        "test": "yarn build:ts && yarn test:legacy && yarn jest --verbose",
        "release:patch": "release-it patch",
        "release:minor": "release-it minor",
        "release:major": "release-it major"
    },
    "dependencies": {
        "bindings": "^1.5.0",
        "cmake-js": "^8.0.0",
        "node-addon-api": "^8.6.0"
    },
    "devDependencies": {
        "@types/bindings": "^1.5.5",
        "@types/jest": "^28.1.3",
        "@types/node": "^18.0.0",
        "conventional-changelog-cli": "^2.2.2",
        "jest": "^28.1.1",
        "release-it": "^19.2.4",
        "rimraf": "^3.0.2",
        "ts-jest": "^28.0.5",
        "ts-node": "^10.8.1",
        "typescript": "^4.7.4"
    },
    "jest": {
        "preset": "ts-jest"
    },
    "release-it": {
        "git": {
            "commitMessage": "release: release v${version}",
            "tagAnnotation": "release: release v${version}"
        },
        "npm": {
            "publish": true
        },
        "hooks": {
            "before:git:release": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md"
        }
    }
}
